# ============================================================
# Environment Variables for Byters Lead Finder
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your actual values below
# 3. NEVER commit your .env file — it is in .gitignore
# ============================================================

# --- FRONTEND (React/Vite) ---
# These are read by src/ via import.meta.env.VITE_*

# Groq API Key — get from https://console.groq.com
VITE_GROQ_KEY=your_groq_api_key_here

# Supabase Project URL — get from Supabase > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key — get from Supabase > Project Settings > API
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
